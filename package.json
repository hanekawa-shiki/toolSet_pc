{
  "name": "vite-tools",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=24",
    "pnpm": "10.34.4"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "pnpm exec lint-staged",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@tailwindcss/vite": "4.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "dayjs": "1.11.21",
    "lucide-react": "1.22.0",
    "lunisolar": "2.6.0",
    "parse-torrent": "11.0.21",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-router": "8.0.1",
    "shadcn": "4.12.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@eslint-react/eslint-plugin": "5.10.0",
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.1",
    "@types/parse-torrent": "5.8.8",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-tailwindcss": "4.0.4",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vite-plugin-node-polyfills": "0.28.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,json}": [
      "eslint --fix"
    ]
  }
}
